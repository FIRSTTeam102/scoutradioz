extends ./layout
block content
	link(rel='stylesheet' type='text/css' href=`${fileRoot}/css/smui.css`)
	link(rel='stylesheet' type='text/css' href=`${fileRoot}/css/tailwind-output.css`)
	link(rel="stylesheet" href="https://voyager.scoutradioz.com/fonts/material-icons.css")
	style.
		#content-container {
			overflow-x: unset;
		}
		input:focus:not(.no-outline) {
			outline: none!important;
		}
		.contact-button {
			position: absolute;
			top: -999px;
		}
		#loading {
			margin: auto;
			border: 8px solid #f3f3f360; /* Light grey */
			border-top: 8px solid #ffffffd2; /* Blue */
			border-radius: 50%;
			width: 80px;
			height: 80px;
			animation: spin 2s linear infinite;
			display: none;
		}

		@keyframes spin {
			0% { transform: rotate(0deg); }
			100% { transform: rotate(360deg); }
		}
		/* Retrieved from https://fonts.googleapis.com/icon?family=Material+Icons at 12-6-2022 */
		/* Font file retrieved from https://fonts.gstatic.com/s/materialicons/v139/flUhRq6tzZclQEJ-Vdg-IuiaDsNc.woff2 at 12-6-2022 */
		/* Both files are licensed with the Apache 2.0 license: https://www.apache.org/licenses/LICENSE-2.0.html (reference: https://fonts.google.com/icons?icon.style=Outlined) */

		/* fallback */
		@font-face {
			font-family: 'Material Icons';
			font-style: normal;
			font-weight: 400;
			src: url(https://fonts.gstatic.com/s/materialicons/v139/flUhRq6tzZclQEJ-Vdg-IuiaDsNc.woff2)
				format('woff2');
		}

		.material-icons {
			font-family: 'Material Icons';
			font-weight: normal;
			font-style: normal;
			font-size: 24px;
			line-height: 1;
			letter-spacing: normal;
			text-transform: none;
			display: inline-block;
			white-space: nowrap;
			word-wrap: normal;
			direction: ltr;
			-webkit-font-feature-settings: 'liga';
			-webkit-font-smoothing: antialiased;
		}
	div.no-outline#svelte-content
	script(type='module').
		const data = JSON.parse(`!{JSON.stringify(data)}`);
		data.title = '#{title}'; // page title
		let mounted = false;
		//- only show loading thing after a short delay
		setTimeout(() => {
			if (!mounted) {
				$('#loading').show();
			}
		}, 250);
		try {
			const App = (await import('/public/svelte/#{page}.js?v=#{functionVersion}')).default
			const { mount } = await import('https://esm.sh/svelte@5.42.3'); // PJL todo: get version from package.json
			const app = mount(App, {
				target: document.getElementById('content'), // content is the id of the main content element
				props: {
					data
				}
			});
			mounted = true;
		}
		catch (err) {
			console.error(err);
			$('#content').append($('<pre>').text(err))
		}
		finally {
			$('#loading').remove();
		}
	//- below: AI trap
	a(href='/contact-us' class='contact-button') Contact Us
	p#loading